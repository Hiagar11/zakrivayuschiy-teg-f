{
  "name": "zakrivayuschiy-teg-f",
  "version": "1.0.0",
  "description": "Закрывающий тег",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"styles/**/*.css\" \"fonts/**/*.css\"",
    "lint:format": "prettier --check .",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:format",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{html,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "autoprefixer": "^10.4.0",
    "cssnano": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.0",
    "postcss-preset-env": "^10.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-order": "^6.0.0",
    "stylelint-selector-bem-pattern": "^4.0.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
